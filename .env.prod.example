# Copiar a .env.prod y completar valores reales:
#   cp .env.prod.example .env.prod

# --- Seguridad (OBLIGATORIO cambiar) ---
# Generar en el servidor: openssl rand -hex 32
SECRET_KEY=CAMBIAR_POR_CLAVE_LARGA_Y_ALEATORIA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- PostgreSQL (contenedor Docker) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_FUERTE
POSTGRES_DB=agropack_llano

# --- Red ---
# Puerto HTTP público (nginx + frontend)
HTTP_PORT=80

# --- App ---
DEBUG=false
