# Frontend Environment Variables (Example)
# Copy this file to .env and adjust values as needed.

# Backend API base URL used by axios calls in the frontend
# Desarrollo (Vite): backend directo
VITE_API_URL=http://localhost:8000
# Producción (build con nginx reverse-proxy): dejar vacío
# VITE_API_URL=

# Notes:
# - During local development with Vite proxy, you can also use relative paths like "/api"
# - For production builds, set this to your real backend URL (https://...)
